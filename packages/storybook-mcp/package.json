{
  "name": "forgekit-storybook-mcp",
  "version": "0.10.6",
  "description": "MCP server for Storybook story generation, component analysis, and validation",
  "author": "Rich Tillman <richtillman@gmail.com>",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "forgekit-storybook-mcp": "./dist/cli.js",
    "storybook-mcp": "./dist/cli.js"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "@forgekit/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "npx tsup src/index.ts src/cli.ts --format esm --dts --clean --tsconfig tsconfig.build.json",
    "prepublishOnly": "npm run build",
    "publish:npm": "npm publish --access public"
  },
  "nx": {
    "tags": [
      "type:mcp",
      "scope:storybook"
    ]
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "fast-glob": "^3.3.2",
    "vitest": "4.0.9"
  },
  "devDependencies": {
    "@types/node": "^20.19.9",
    "tsup": "^8.5.1"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "storybook",
    "mcp",
    "model-context-protocol",
    "code-generation",
    "react",
    "component-library",
    "testing"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/effinrich/forgekit.git"
  },
  "homepage": "https://forgekit.cloud"
}
