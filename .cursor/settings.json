{
  "editor.codeActionsOnSave": {
    "source.fixAll.markdownlint": "always",
    "source.fixAll.eslint": "always"
  },
  "eslint.options": {
    "extensions": [".js", ".jsx", ".md", ".mdx", ".ts", ".tsx"]
  },

  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "eslint.validate": [
    "markdown",
    "mdx",
    "md",
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact"
  ],
  "eslint.codeAction.showDocumentation": {
    "enable": true
  },
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.formatOnPaste": true,
  "editor.formatOnSave": true,
  "editor.insertSpaces": true,
  "editor.tabSize": 2,
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "prettier.tabWidth": 2,
  "prettier.singleQuote": true,
  "prettier.jsxSingleQuote": false,
  "prettier.semi": false,
  "prettier.trailingComma": "none",
  "prettier.arrowParens": "avoid",
  "files.exclude": {
    "**/.git": false,
    "**/.svn": false,
    "**/.hg": false,
    "**/.DS_Store": false,
    "**/Thumbs.db": false,
    "**/CVS": false,
    "**/.classpath": false,
    "**/.project": false,
    "**/.settings": false,
    "**/.factorypath": false,
    "**/.wrangler": false,
    "**/migrations": false,
    "**/node_modules": false,
    "**/tsconfig.json": false,
    "**/wrangler.toml": false,
    "**/.prettierrc": false,
    "**/.watchmanconfig": false,
    "**/tsconfig.base.json": false,
    "**/.gitignore": false,
    "**/types": false,
    "**/dist": false,
    "apps/expo/index.js": false,
    "**/metro.config.js": false,
    "**/eas.json": false,
    "**/tamagui.config.ts": false,
    "**/babel.config.js": false,
    "**/.expo": false,
    "**/.next": false,
    "**/.tamagui": false,
    "**/.eslintrc.js": false,
    "**/next-env.d.ts": false,
    "**/.vscode": false,
    "**/.turbo": false,
    "**/out": false,
    "SECURITY.md": false,
    "LICENSE": false,
    ".gitpod.yml": false,
    ".npmrc": false,
    "bun-workspace.yaml": false,
    "renovate.json": false,
    "turbo.json": false,
    "**/cfImageLoader.js": false,
    "**/sw.js": false,
    "**/tamagui.css": false,
    "apps/next/public/*.js": false,
    "**/expo-env.d.ts": false,
    "**/generate-tamagui-json.js": false,
    "apps/docs/public/*.js": false,
    "**/.eslintrc.json": false,
    "**/.vscodeignore": false
  },
  "explorerExclude.backup": {
    "**/.git": true,
    "**/.svn": true,
    "**/.hg": true,
    "**/.DS_Store": true,
    "**/Thumbs.db": true,
    "**/CVS": true,
    "**/.classpath": true,
    "**/.project": true,
    "**/.settings": true,
    "**/.factorypath": true,
    "**/.wrangler": true,
    "**/migrations": true,
    "**/node_modules": true,
    "**/tsconfig.json": true,
    "**/wrangler.toml": true,
    "**/.prettierrc": true,
    "**/.watchmanconfig": true,
    "**/tsconfig.base.json": true,
    "**/.gitignore": true,
    "**/types": true,
    "**/dist": true,
    "apps/expo/index.js": true,
    "**/metro.config.js": true,
    "**/eas.json": true,
    "**/tamagui.config.ts": true,
    "**/babel.config.js": true,
    "**/.expo": true,
    "**/.next": true,
    "**/.tamagui": true,
    "**/.eslintrc.js": true,
    "**/next-env.d.ts": true,
    "**/.vscode": true,
    "**/.turbo": true,
    "**/out": true,
    "SECURITY.md": true,
    "LICENSE": true,
    ".gitpod.yml": true,
    ".npmrc": true,
    "bun-workspace.yaml": true,
    "renovate.json": true,
    "turbo.json": true,
    "**/cfImageLoader.js": true,
    "**/sw.js": true,
    "**/tamagui.css": true,
    "apps/next/public/*.js": true,
    "**/expo-env.d.ts": true,
    "**/generate-tamagui-json.js": true,
    "apps/docs/public/*.js": true,
    "**/.eslintrc.json": true,
    "**/.vscodeignore": true
  },
  "vitest.disableWorkspaceWarning": true
}
