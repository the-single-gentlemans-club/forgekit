{
  "name": "@forgekit/source",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "lint": "nx run-many -t lint --fix",
    "test": "nx run-many -t test --fix",
    "build": "nx run-many -t build",
    "typecheck": "nx run-many -t typecheck --fix",
    "release": "nx release",
    "release:version": "nx release version",
    "release:changelog": "nx release changelog --fix",
    "publish:figma-plugin": "nx run figma-plugin:nx-release-publish"
  },
  "private": true,
  "devDependencies": {
    "@eslint/js": "^9.8.0",
    "@figma/plugin-typings": "^1.123.0",
    "@nx/eslint": "^22.5.1",
    "@nx/eslint-plugin": "^22.5.1",
    "@nx/js": "^22.5.1",
    "@nx/vite": "^22.5.1",
    "@nx/vitest": "^22.5.1",
    "@nx/web": "^22.5.1",
    "@swc-node/register": "1.11.1",
    "@swc/core": "1.15.8",
    "@swc/helpers": "0.5.18",
    "@types/node": "^20.19.9",
    "@vitest/coverage-v8": "4.0.9",
    "@vitest/ui": "4.0.9",
    "ajv": "^8.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react": "^7.33.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "husky": "^9.0.0",
    "jiti": "2.4.2",
    "jsdom": "^27.1.0",
    "jsonc-eslint-parser": "^2.1.0",
    "lint-staged": "^15.0.0",
    "nx": "^22.5.2",
    "prettier": "^3.0.0",
    "prettier-plugin-tailwindcss": "^0.6.0",
    "tslib": "^2.8.1",
    "tsup": "^8.5.1",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.40.0",
    "verdaccio": "^6.2.5",
    "vite": "^7.0.0",
    "vite-plugin-dts": "~4.5.0",
    "vitest": "4.0.9"
  },
  "workspaces": [
    "packages/*"
  ],
  "nx": {
    "includedScripts": [],
    "targets": {
      "local-registry": {
        "executor": "@nx/js:verdaccio",
        "options": {
          "port": 4873,
          "config": ".verdaccio/config.yml",
          "storage": "tmp/local-registry/storage"
        }
      }
    }
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "fast-glob": "^3.3.3"
  }
}
